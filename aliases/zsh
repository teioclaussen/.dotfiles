alias reload='. ~/.zshrc'

# Pipe my public key to my clipboard.
alias pubkey="more ~/.ssh/id_rsa.pub | pbcopy | echo '=> Public key copied to pasteboard.'"
alias cls='clear'
alias vi='vim'
alias ll='ls -la'
alias myip='curl http://ipecho.net/plain; echo'
alias ffs='sudo !!'
alias zshcfg='vim $HOME./zshrc'
alias -g G='| grep -i'
